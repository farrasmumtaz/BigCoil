generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  tagline   String
  logo      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  address   String
  email     String
  facebook  String?
  instagram String?
  shopee    String?
  tiktok    String?
  tokopedia String?
  whatsapp  String

  @@map("company")
}

model Hero {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String?
  description String   @db.Text
  buttonText  String
  buttonLink  String
  image       String
  updatedAt   DateTime @updatedAt

  @@map("hero")
}

model CollectionCategory {
  id          Int          @id @default(autoincrement())
  name        String       @unique(map: "CollectionCategory_name_key")
  slug        String       @unique(map: "CollectionCategory_slug_key")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  collections Collection[]

  @@map("collectioncategory")
}

model Collection {
  id          Int                @id @default(autoincrement())
  title       String
  description String             @db.Text
  createdAt   DateTime           @default(now())
  slug        String             @unique(map: "Collection_slug_key")
  updatedAt   DateTime           @updatedAt
  coverImage  String
  categoryId  Int
  category    CollectionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  detail      CollectionDetail?
  products    Product[]

  @@index([categoryId], map: "collection_categoryId_fkey")
  @@map("collection")
}

model CollectionDetail {
  id              Int        @id @default(autoincrement())
  collectionId    Int        @unique(map: "CollectionDetail_collectionId_key")
  heroImage       String
  heroTitle       String
  heroDescription String     @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@map("collectiondetail")
}

model Product {
  id                    Int                    @id @default(autoincrement())
  collectionId          Int
  title                 String
  slug                  String                 @unique(map: "Product_slug_key")
  shortDescription      String                 @db.Text
  heroImage             String
  videoUrl              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  collection            Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  descriptions          ProductDescription[]
  galleries             ProductGallery[]
  productSpecifications ProductSpecification[]
  productTechnologies   ProductTechnology[]

  @@index([collectionId], map: "product_collectionId_fkey")
  @@map("product")
}

model ProductGallery {
  id        Int      @id @default(autoincrement())
  productId Int
  image     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "productgallery_productId_fkey")
  @@map("productgallery")
}

model ProductSpecification {
  id        Int      @id @default(autoincrement())
  productId Int
  label     String
  value     String
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "productspecification_productId_fkey")
  @@map("productspecification")
}

model ProductDescription {
  id          Int      @id @default(autoincrement())
  productId   Int
  title       String
  description String   @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "productdescription_productId_fkey")
  @@map("productdescription")
}

model Technology {
  id          Int                 @id @default(autoincrement())
  title       String
  description String              @db.Text
  image       String
  subtitle    String?
  createdAt   DateTime            @default(now())
  type        TechnologyType
  updatedAt   DateTime            @updatedAt
  products    ProductTechnology[]

  @@map("technology")
}

model ProductTechnology {
  id           Int        @id @default(autoincrement())
  productId    Int
  technologyId Int
  sortOrder    Int        @default(0)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@unique([productId, technologyId], map: "ProductTechnology_productId_technologyId_key")
  @@index([technologyId], map: "producttechnology_technologyId_fkey")
  @@map("producttechnology")
}

model DreamBetter {
  id          Int                  @id @default(autoincrement())
  title       String
  slug        String               @unique(map: "DreamBetter_slug_key")
  description String               @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  heroImage   String
  sections    DreamBetterSection[]

  @@map("dreambetter")
}

model DreamBetterSection {
  id            Int         @id @default(autoincrement())
  dreamBetterId Int
  title         String
  content       String      @db.Text
  order         Int
  dreamBetter   DreamBetter @relation(fields: [dreamBetterId], references: [id], onDelete: Cascade)

  @@index([dreamBetterId], map: "dreambettersection_dreamBetterId_fkey")
  @@map("dreambettersection")
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  image     String
  updatedAt DateTime @updatedAt

  @@map("testimonial")
}

model Dealer {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  address   String   @db.Text
  phone     String?
  mapsUrl   String?
  createdAt DateTime @default(now())
  island    String
  province  String
  updatedAt DateTime @updatedAt

  @@map("dealer")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contactmessage")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique(map: "Admin_username_key")
  password  String
  createdAt DateTime @default(now())

  @@map("admin")
}

model AboutCompany {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String
  description String   @db.Text
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("aboutcompany")
}

model AboutBrand {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("aboutbrand")
}

model Exhibition {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique(map: "Exhibition_slug_key")
  location    String
  eventDate   DateTime
  description String   @db.Text
  coverImage  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("exhibition")
}

model ServiceCenter {
  id        Int      @id @default(autoincrement())
  name      String
  island    String
  province  String
  city      String
  address   String   @db.Text
  phone     String?
  mapsUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("servicecenter")
}

model ServiceSetting {
  id        Int      @id @default(1)
  embedUrl  String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("servicesetting")
}

enum TechnologyType {
  COIL
  FOAM
}

model Warranty {
  id          Int      @id @default(autoincrement())

  title       String
  description String   @db.Text
  heroImage   String

  items WarrantyItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warranty")
}

model WarrantyItem {
  id Int @id @default(autoincrement())

  warrantyId Int

  title String

  description String? @db.Text

  image String?

  sortOrder Int @default(0)

  warranty Warranty @relation(fields: [warrantyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warrantyitem")
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  image       String

  category    String

  publishDate DateTime

  link        String
  sortOrder    Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("article")
}