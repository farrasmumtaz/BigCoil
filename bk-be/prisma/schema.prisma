// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id Int @id @default(autoincrement())

  name    String
  tagline String
  address String

  logo String

  whatsapp String
  email    String

  facebook  String?
  instagram String?
  tiktok    String?

  shopee    String?
  tokopedia String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company")
}

model Hero {
  id Int @id @default(autoincrement())

  title       String
  subtitle    String?
  description String  @db.Text

  buttonText String
  buttonLink String

  image String

  updatedAt DateTime @updatedAt

  @@map("hero")
}

model CollectionCategory {
  id Int @id @default(autoincrement())

  name String @unique
  slug String @unique

  collections Collection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("collectioncategory")
}

model Collection {
  id Int @id @default(autoincrement())

  categoryId Int

  title String
  slug  String @unique

  description String @db.Text

  coverImage String

  category CollectionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  products Product[]

  detail CollectionDetail?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("collection")
}

model CollectionDetail {
  id Int @id @default(autoincrement())

  collectionId Int @unique

  heroImage String

  heroTitle String

  heroDescription String @db.Text

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("collectiondetail")
}

model Product {
  id Int @id @default(autoincrement())

  collectionId Int

  title String
  slug  String @unique

  shortDescription String @db.Text

  heroImage String

  videoUrl String?

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  galleries ProductGallery[]

  descriptions ProductDescription[]

  productSpecifications ProductSpecification[]

  productTechnologies ProductTechnology[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("product")
}

model ProductGallery {
  id Int @id @default(autoincrement())

  productId Int

  image String

  sortOrder Int @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("productgallery")
}

model ProductSpecification {
  id Int @id @default(autoincrement())

  productId Int

  label String

  value String

  icon String?

  sortOrder Int @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("productspecification")
}

model ProductDescription {
  id Int @id @default(autoincrement())

  productId Int

  title String

  description String @db.Text

  sortOrder Int @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("productdescription")
}

enum TechnologyType {
  COIL
  FOAM
}

model Technology {
  id Int @id @default(autoincrement())

  type TechnologyType

  title String

  subtitle String?

  description String @db.Text

  image String

  products ProductTechnology[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("technology")
}

model ProductTechnology {
  id Int @id @default(autoincrement())

  productId Int

  technologyId Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0)

  @@unique([productId, technologyId])

  @@map("producttechnology")
}

model DreamBetter {
  id Int @id @default(autoincrement())

  title String

  slug String @unique

  description String @db.Text

  heroImage String

  sections DreamBetterSection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dreambetter")
}

model DreamBetterSection {
  id Int @id @default(autoincrement())

  dreamBetterId Int

  title String

  content String @db.Text

  order Int

  dreamBetter DreamBetter@relation(fields: [dreamBetterId], references: [id], onDelete: Cascade)

  @@map("dreambettersection")
}

model Testimonial {
  id Int @id @default(autoincrement())

  image String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonial")
}

model Dealer {
  id Int @id @default(autoincrement())

  name String

  island String

  province String

  city String

  address String @db.Text

  phone String?

  mapsUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dealer")
}

model ContactMessage {
  id Int @id @default(autoincrement())

  name String

  email String

  phone String?

  message String @db.Text

  createdAt DateTime @default(now())

  @@map("contactmessage")
}

model Admin {
  id Int @id @default(autoincrement())

  username String @unique

  password String

  createdAt DateTime @default(now())

  @@map("admin")
}

model AboutCompany {
  id Int @id @default(autoincrement())

  title String

  subtitle String

  description String @db.Text

  image String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("aboutcompany")
}

model AboutBrand {
  id Int @id @default(autoincrement())

  title String

  description String @db.Text

  image String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("aboutbrand")
}

model Exhibition {
  id Int @id @default(autoincrement())

  title String
  slug String @unique

  location String

  eventDate DateTime

  description String @db.Text

  coverImage String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exhibition")
}

model ServiceCenter {
  id Int @id @default(autoincrement())

  name String

  island String

  province String

  city String

  address String @db.Text

  phone String?

  mapsUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("servicecenter")
}

model ServiceSetting {
  id Int @id @default(1)

  embedUrl String @db.Text

  updatedAt DateTime @updatedAt

  @@map("servicesetting")
}
